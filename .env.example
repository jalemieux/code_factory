# Copy to `.env` (next to code_factory.py) and fill in.
# `.env` overrides anything you've exported in your shell, so this file is
# the source of truth for which GitHub identity the bot uses.

# GitHub token the bot acts as. Use a fine-grained PAT with repo
# Contents/Pull requests/Issues read+write, or a GitHub App installation
# token. `gh` and `git` will both use this.
GH_TOKEN=

# Author/committer identity for commits the bot makes. If unset, git falls
# back to your global git config — usually your personal name/email, which
# you probably don't want on bot commits.
GIT_AUTHOR_NAME=code-factory-bot
GIT_AUTHOR_EMAIL=bot@example.com
